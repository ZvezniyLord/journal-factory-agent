{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "conference-metadata.schema.json",
  "type": "object",
  "required": [
    "schema_version",
    "conference_id",
    "event_title",
    "dates",
    "location",
    "conference_url",
    "doi_url",
    "isbn",
    "udc",
    "typography_profile",
    "template_replacements",
    "required_markers",
    "stale_markers",
    "provenance"
  ],
  "properties": {
    "schema_version": {"const": 1},
    "conference_id": {"type": "integer", "minimum": 1},
    "event_title": {"type": "string", "minLength": 1},
    "dates": {"type": "string", "minLength": 1},
    "location": {"type": "string", "minLength": 1},
    "conference_url": {"type": "string", "format": "uri"},
    "doi_url": {"type": "string", "format": "uri"},
    "isbn": {"type": "string", "minLength": 1},
    "udc": {"type": "string", "minLength": 1},
    "typography_profile": {"type": "string", "minLength": 1},
    "template_replacements": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["source", "target"],
        "properties": {
          "source": {"type": "string", "minLength": 1},
          "target": {"type": "string", "minLength": 1},
          "preserve_case": {"type": "boolean"}
        },
        "additionalProperties": false
      }
    },
    "dynamic_fields": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["placeholder", "field"],
        "properties": {
          "placeholder": {"type": "string", "minLength": 1},
          "field": {"type": "string", "minLength": 1}
        },
        "additionalProperties": false
      }
    },
    "service_layout": {
      "type": "object",
      "properties": {
        "trim_trailing_empty_paragraphs": {"type": "boolean"},
        "preceding_empty_paragraph_font": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["marker", "font_size_pt"],
            "properties": {
              "marker": {"type": "string", "minLength": 1},
              "font_size_pt": {"type": "number", "exclusiveMinimum": 0}
            },
            "additionalProperties": false
          }
        }
      },
      "additionalProperties": false
    },
    "required_markers": {
      "type": "array",
      "minItems": 1,
      "items": {"type": "string", "minLength": 1}
    },
    "stale_markers": {
      "type": "array",
      "minItems": 1,
      "items": {"type": "string", "minLength": 1}
    },
    "provenance": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["field", "source", "confidence"],
        "properties": {
          "field": {"type": "string", "minLength": 1},
          "source": {"type": "string", "minLength": 1},
          "confidence": {"type": "number", "minimum": 0, "maximum": 1}
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": true
}
