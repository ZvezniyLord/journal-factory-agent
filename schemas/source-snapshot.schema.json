{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://naukainfo.local/schemas/source-snapshot.schema.json",
  "type": "object",
  "required": [
    "source_path",
    "source_sha256",
    "visible_text",
    "paragraphs",
    "runs",
    "paragraph_order",
    "tables",
    "table_cells",
    "merge_map",
    "numbering",
    "images",
    "media_hashes",
    "relationships",
    "drawings",
    "shapes",
    "textboxes",
    "charts",
    "equations",
    "OLE",
    "section_breaks",
    "page_breaks",
    "object_risk",
    "unsupported_parts",
    "snapshot_status"
  ],
  "properties": {
    "source_path": { "type": "string" },
    "source_sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
    "visible_text": { "type": "string" },
    "paragraphs": { "type": "array" },
    "runs": { "type": "array" },
    "paragraph_order": { "type": "array", "items": { "type": "integer" } },
    "tables": { "type": "array" },
    "table_cells": { "type": "array" },
    "merge_map": { "type": "array" },
    "numbering": { "type": "object" },
    "styles": { "type": "object" },
    "images": { "type": "array", "items": { "type": "string" } },
    "media_hashes": { "type": "object" },
    "relationships": { "type": "array" },
    "drawings": { "type": "integer", "minimum": 0 },
    "shapes": { "type": "integer", "minimum": 0 },
    "textboxes": { "type": "array" },
    "charts": { "type": "array", "items": { "type": "string" } },
    "equations": { "type": "integer", "minimum": 0 },
    "OLE": { "type": "array", "items": { "type": "string" } },
    "section_breaks": { "type": "integer", "minimum": 0 },
    "page_breaks": { "type": "integer", "minimum": 0 },
    "object_risk": { "type": "string" },
    "unsupported_parts": { "type": "array", "items": { "type": "string" } },
    "conversion_method": { "type": ["string", "null"] },
    "converted_sha256": { "type": ["string", "null"] },
    "warnings": { "type": "array", "items": { "type": "string" } },
    "blockers": { "type": "array", "items": { "type": "string" } },
    "snapshot_status": { "enum": ["PASS", "BLOCKED"] }
  },
  "additionalProperties": true
}
